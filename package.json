{
  "name": "worldcupiq",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered smart prediction & analytics platform for the Injective Global Cup",
  "workspaces": [
    "frontend",
    "contracts",
    "x402-gateway",
    "cctp",
    "mcp-server",
    "agent-skill"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:gateway": "npm run dev -w x402-gateway",
    "dev:mcp": "npm run dev -w mcp-server",
    "build:contracts": "npm run build -w contracts",
    "docker:up": "docker-compose up --build"
  },
  "engines": {
    "node": ">=18"
  }
}
